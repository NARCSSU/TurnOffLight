{
  "manifest_version": 3,
  "name": "Dark Mode Switch",
  "version": "1.0.0",
  "description": "Convert web pages to dark mode for better ergonomic viewing experience.",
  "author": "Dark Mode Switch Team",
  "minimum_chrome_version": "109",
  "browser_specific_settings": {
    "gecko": {
      "id": "dark-mode-switch@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "theme"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content_scripts/dark-mode.css",
        "content_scripts/lightbox.css"
      ],
      "js": [
        "content_scripts/dark-mode.js",
        "content_scripts/lightbox.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-off-16.png",
      "32": "icons/icon-off-32.png",
      "48": "icons/icon-off-48.png",
      "128": "icons/icon-off-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-off-16.png",
    "32": "icons/icon-off-32.png",
    "48": "icons/icon-off-48.png",
    "128": "icons/icon-off-128.png"
  },
  "options_page": "options/options.html"
}